@page
@model Tekken8.Pages.CharactersModel
@{
    ViewData["Title"] = "Tekken 8 Characters";
}

<div class="container mt-5">
    <h1 class="mb-4">Tekken 8 Characters</h1>

    <div class="row">
        @if (Model.ImagePaths != null && Model.ImagePaths.Count > 0)
        {
            @foreach (var imagePath in Model.ImagePaths)
            {
                <div class="col-md-4 col-lg-3 mb-4">
                    <div class="card h-100 shadow-sm">
                        <img src="@imagePath" class="card-img-top" alt="Character" style="height: 300px; object-fit: cover;">
                        <div class="card-body d-flex align-items-center justify-content-center">
                            <h5 class="card-title text-center">@System.IO.Path.GetFileNameWithoutExtension(imagePath)</h5>
                        </div>
                    </div>
                </div>  
            }
        }
        else
        {
            <div class="col-12">
                <p class="text-center">No character images found. Please add images to the wwwroot/images folder.</p>
            </div>
        }
    </div>
</div>

<style>
    .card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 16px rgba(0, 0, 0, 0.2) !important;
    }
</style>
